@model CrudMVC.Models.Cliente
@{ ViewData["Title"] = "Eliminar Cliente"; }

<h2>¿Eliminar este cliente?</h2>

<div class="card" style="max-width:400px">
    <div class="card-body">
        <p><strong>Nombre:</strong>   @Model.Nombre</p>
        <p><strong>Email:</strong>    @Model.Email</p>
        <p><strong>Teléfono:</strong> @Model.Telefono</p>
        <p><strong>Ciudad:</strong>   @Model.Ciudad</p>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input name="id" type="hidden" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>